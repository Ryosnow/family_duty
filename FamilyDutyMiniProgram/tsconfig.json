{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "miniprogram-api-typings", "vitest/globals"]
  },
  "include": ["miniprogram/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
