.task-card { padding: 26rpx; border: 1rpx solid #dfe5e1; border-radius: 28rpx; background: #fff; box-shadow: 0 10rpx 30rpx rgba(31,77,59,.06); }
.task-card-overdue { border-color: #ecc0ba; }
.top-row { display: flex; align-items: flex-start; gap: 20rpx; }
.icon-wrap { display: flex; flex: none; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; border-radius: 24rpx; background: #e4f0e9; }
.icon-danger { background: #fbe9e6; }
.icon { width: 42rpx; height: 42rpx; }
.content { min-width: 0; flex: 1; }
.title-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.title { font-size: 32rpx; font-weight: 750; line-height: 1.35; }
.status { flex: none; padding: 5rpx 13rpx; border-radius: 999rpx; background: #e4f0e9; color: #2e7d5b; font-size: 21rpx; font-weight: 700; }
.danger { background: #fbe9e6; color: #c7483d; }
.member-row { display: flex; align-items: center; gap: 10rpx; margin-top: 16rpx; font-size: 26rpx; }
.avatar { display: flex; align-items: center; justify-content: center; width: 46rpx; height: 46rpx; border-radius: 50%; background: #dce9e3; color: #1f4d3b; font-size: 22rpx; font-weight: 800; }
.avatar-blue { background: #dce8f7; color: #275d99; }.avatar-purple { background: #e8e0f2; color: #654b93; }.avatar-orange { background: #f8e5d5; color: #9b4f20; }.avatar-green { background: #dceee3; color: #28734b; }.avatar-pink { background: #f4dce7; color: #9a3e65; }.avatar-teal { background: #d5eeee; color: #176d70; }
.score { margin-left: auto; color: #1f4d3b; font-weight: 750; }
.meta, .note { display: block; margin-top: 12rpx; color: #68736d; font-size: 23rpx; line-height: 1.5; }
.note { color: #8b5d20; }
.actions { display: flex; justify-content: flex-end; gap: 12rpx; margin-top: 22rpx; padding-top: 18rpx; border-top: 1rpx solid #edf0ee; }
.action { min-width: 112rpx; min-height: 68rpx; margin: 0; padding: 0 20rpx; border: 1rpx solid #cbd6d0; border-radius: 18rpx; background: #fff; color: #1f4d3b; font-size: 24rpx; line-height: 68rpx; }
.primary { border-color: #1f4d3b; background: #1f4d3b; color: #fff; }
.action::after { border: none; }
@media (prefers-color-scheme: dark) { .task-card, .action { border-color: #38453e; background: #1b241f; color: #edf4ef; } .actions { border-color: #354139; } .score { color: #82c8a4; } .meta { color: #a9b5ae; } }
