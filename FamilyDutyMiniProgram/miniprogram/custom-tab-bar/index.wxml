<cover-view class="tabbar" aria-role="tablist">
  <cover-view wx:for="{{list}}" wx:key="pagePath" class="tab {{selected === index ? 'selected' : ''}}" data-index="{{index}}" bindtap="switchTab" aria-role="tab" aria-label="{{item.text}}" aria-selected="{{selected === index}}">
    <cover-view class="indicator"></cover-view>
    <cover-view class="label">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
