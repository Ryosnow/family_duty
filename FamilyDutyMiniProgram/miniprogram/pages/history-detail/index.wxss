.detail-hero { display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:22rpx;padding:38rpx;border-radius:40rpx 40rpx 14rpx 40rpx;background:#1f4d3b;color:#fff; }.detail-icon { width:70rpx;height:70rpx;padding:18rpx;border-radius:22rpx;background:#e7f2ec; }.detail-title { font-size:40rpx;font-weight:800; }.detail-score { color:#f4c36e;font-size:34rpx;font-weight:800; }.detail-list view { display:flex;align-items:flex-start;justify-content:space-between;gap:30rpx;min-height:90rpx;padding:18rpx 0;border-bottom:1rpx solid #edf0ee; }.detail-list view:last-child { border-bottom:none; }.detail-list text { color:#68736d; }.detail-list strong { text-align:right; }.recreate { width:100%;margin-top:28rpx; }
@media (prefers-color-scheme:dark) { .detail-list view { border-color:#354139; } }
