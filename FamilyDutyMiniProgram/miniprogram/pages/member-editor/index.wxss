.preview { display:flex;align-items:center;justify-content:center;width:128rpx;height:128rpx;margin:10rpx auto 34rpx;border-radius:50%;background:#dce8f7;color:#275d99;font-size:50rpx;font-weight:800; }.avatar-purple { background:#e8e0f2;color:#654b93; }.avatar-orange { background:#f8e5d5;color:#9b4f20; }.avatar-green { background:#dceee3;color:#28734b; }.avatar-pink { background:#f4dce7;color:#9a3e65; }.avatar-teal { background:#d5eeee;color:#176d70; }.colors { display:flex;flex-wrap:wrap;gap:22rpx; }.color { width:72rpx;height:72rpx;margin:0;border:8rpx solid transparent;border-radius:50%;background:#4b7ec3; }.color-purple { background:#7a57b8; }.color-orange { background:#d96e29; }.color-green { background:#2e8757; }.color-pink { background:#c24d7b; }.color-teal { background:#19858a; }.color.selected { border-color:#fff;box-shadow:0 0 0 5rpx #1f4d3b; }.save { width:100%;margin-top:28rpx; }
