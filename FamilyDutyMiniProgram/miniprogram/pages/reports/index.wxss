.kind-tabs { display:flex;padding:8rpx;border-radius:24rpx;background:#e5e9e6; }.kind { flex:1;min-height:72rpx;margin:0;border-radius:18rpx;background:transparent;color:#5c6962;font-size:26rpx;line-height:72rpx; }.kind.selected { background:#fff;color:#1f4d3b;font-weight:800;box-shadow:0 5rpx 18rpx rgba(31,77,59,.08); }.period-row { display:flex;align-items:center;justify-content:center;gap:22rpx;margin:28rpx 0; }.period-button { width:72rpx;height:72rpx;margin:0;border-radius:50%;background:#fff;color:#1f4d3b;font-size:46rpx;line-height:68rpx; }.period-title { min-width:360rpx;text-align:center;font-weight:750; }.metrics { display:grid;grid-template-columns:1fr 1fr;gap:20rpx; }.metric { padding:28rpx;border-radius:30rpx;color:#fff; }.metric text,.metric strong { display:block; }.metric text { opacity:.78;font-size:24rpx; }.metric strong { margin-top:8rpx;font-size:50rpx; }.dark { background:#1f4d3b; }.warm { background:#b8761d; }.summary-row,.point-row { display:grid;grid-template-columns:1fr auto auto;gap:20rpx;align-items:center;min-height:76rpx;border-top:1rpx solid #edf0ee;font-size:25rpx; }.chart { width:100%;height:360rpx; }.history-link { display:flex;align-items:center;gap:18rpx;width:100%;min-height:100rpx;margin-top:34rpx;padding:0 26rpx;border-radius:24rpx;background:#fff;color:#1f4d3b;font-weight:750;text-align:left; }.history-link text { margin-left:auto;font-size:40rpx; }
@media (prefers-color-scheme:dark) { .kind-tabs { background:#26312b; }.kind.selected,.period-button,.history-link { background:#1b241f;color:#edf4ef; }.summary-row,.point-row { border-color:#354139; } }
