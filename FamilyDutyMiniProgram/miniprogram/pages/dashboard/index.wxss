.hero { position: relative; display: flex; overflow: hidden; min-height: 310rpx; padding: 42rpx; border-radius: 42rpx 42rpx 42rpx 12rpx; background: #1f4d3b; color: #fff; }
.hero::after { content: ""; position: absolute; right: -70rpx; top: -100rpx; width: 300rpx; height: 300rpx; border: 48rpx solid rgba(255,255,255,.08); border-radius: 50%; }
.hero-copy { z-index: 1; max-width: 470rpx; }
.date { display: block; color: #b9d7c8; font-size: 25rpx; }.hero-title { display: block; margin-top: 20rpx; font-size: 43rpx; font-weight: 800; }.hero-subtitle { display: block; margin-top: 15rpx; color: rgba(255,255,255,.78); font-size: 25rpx; }.hero-button { width: auto; margin-top: 26rpx; }
.progress { z-index: 1; align-self: center; width: 160rpx; margin-left: auto; text-align: center; }.progress-value { font-size: 40rpx; font-weight: 800; }.progress-label { color: #bdd5c9; font-size: 22rpx; }.progress-bar { height: 12rpx; margin-top: 18rpx; overflow: hidden; border-radius: 12rpx; background: rgba(255,255,255,.18); }.progress-fill { height: 100%; border-radius: 12rpx; background: #e89b29; }
.section-title view { display:flex;align-items:center;gap:12rpx; }.history-list { padding-top: 8rpx; padding-bottom: 8rpx; }.history-row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; min-height: 96rpx; border-bottom: 1rpx solid #edf0ee; }.history-row:last-child { border-bottom: none; }.history-title, .history-meta { display:block; }.history-title { font-weight:700; }.history-meta { margin-top:7rpx;color:#68736d;font-size:23rpx; }
@media (max-width: 360px) { .hero { padding: 34rpx; }.progress { width: 130rpx; }.hero-title { font-size: 38rpx; } }
