.summary-card { border-radius: 38rpx 38rpx 14rpx 38rpx; }.summary-card .section-title { margin-bottom:0; }.metrics { display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin:26rpx 0; }.metrics>view { padding:22rpx;border-radius:22rpx;background:#eef5f1; }.metric-value,.metric-label { display:block; }.metric-value { color:#1f4d3b;font-size:44rpx;font-weight:800; }.metric-label { margin-top:4rpx;color:#68736d;font-size:23rpx; }.member-summary { display:grid;grid-template-columns:1fr auto auto;gap:20rpx;align-items:center;min-height:70rpx;border-top:1rpx solid #edf0ee;font-size:25rpx; }
@media (prefers-color-scheme:dark) { .metrics>view { background:#25332b; }.metric-value { color:#82c8a4; }.member-summary { border-color:#354139; } }
