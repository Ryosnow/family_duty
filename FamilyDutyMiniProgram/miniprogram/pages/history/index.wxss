.filters { display:flex;flex-direction:column;gap:18rpx; }.filter-grid { display:grid;grid-template-columns:1fr 1fr;gap:16rpx; }.records { padding-top:6rpx;padding-bottom:6rpx; }.record { display:grid;grid-template-columns:1fr auto auto;align-items:center;gap:18rpx;min-height:112rpx;border-bottom:1rpx solid #edf0ee; }.record:last-child { border-bottom:none; }.record-title,.record-meta { display:block; }.record-title { font-weight:750; }.record-meta { margin-top:8rpx;color:#68736d;font-size:23rpx; }.arrow { color:#87928c;font-size:40rpx; }
@media (prefers-color-scheme:dark) { .record { border-color:#354139; } }
