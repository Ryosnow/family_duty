.section-title view { display:flex;align-items:center;gap:12rpx; }.member-list { padding-top:5rpx;padding-bottom:5rpx; }.member-row { display:flex;align-items:center;gap:12rpx;min-height:102rpx;border-bottom:1rpx solid #edf0ee; }.member-row:last-child { border-bottom:none; }.avatar { display:flex;align-items:center;justify-content:center;width:62rpx;height:62rpx;border-radius:50%;background:#dce9e3;color:#1f4d3b;font-size:25rpx;font-weight:800; }.avatar-blue { background:#dce8f7;color:#275d99; }.avatar-purple { background:#e8e0f2;color:#654b93; }.avatar-orange { background:#f8e5d5;color:#9b4f20; }.avatar-green { background:#dceee3;color:#28734b; }.avatar-pink { background:#f4dce7;color:#9a3e65; }.avatar-teal { background:#d5eeee;color:#176d70; }.member-name { flex:1;font-weight:700; }.mini { min-width:58rpx;min-height:58rpx;margin:0;padding:0 12rpx;border-radius:15rpx;background:#f1f5f2;color:#1f4d3b;font-size:22rpx;line-height:58rpx; }.setting-row { display:flex;align-items:center;justify-content:space-between;min-height:96rpx;border-top:1rpx solid #edf0ee; }.reminder-note,.backup-note,.storage { display:block;color:#68736d;font-size:24rpx;line-height:1.6; }.reminder-note { margin-bottom:18rpx; }.time { padding:15rpx 22rpx;border-radius:16rpx;background:#eef4f0;color:#1f4d3b;font-weight:700; }.storage-title { display:block;font-weight:700; }.data-icon { width:62rpx;height:62rpx;padding:14rpx;border-radius:20rpx;background:#e4f0e9; }.backup-note { margin-top:22rpx; }.backup-actions { display:grid;grid-template-columns:1fr 1fr;gap:16rpx;margin-top:26rpx; }.backup-actions button { width:100%; }
@media (prefers-color-scheme:dark) { .member-row,.setting-row { border-color:#354139; }.mini,.time { background:#26332c;color:#edf4ef; } }
