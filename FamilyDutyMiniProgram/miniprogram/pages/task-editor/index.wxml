<view class="page-shell" wx:if="{{ready}}">
  <view class="page-title">{{mode === 'adjust' ? '调整任务' : '新增临时任务'}}</view>
  <view wx:if="{{mode === 'create'}}" class="section"><view class="field-label">常用家务</view><view class="chip-row"><button class="chip {{title === item ? 'chip-selected' : ''}}" wx:for="{{presets}}" wx:key="*this" data-title="{{item}}" bindtap="selectPreset">{{item}}</button></view></view>
  <view class="section card"><view class="field"><text class="field-label">任务名称</text><input class="input" value="{{title}}" placeholder="输入任务名称" bindinput="updateTitle" /></view><view class="field"><text class="field-label">计划日期</text><picker mode="date" value="{{date}}" bindchange="updateDate"><view class="picker">{{date}}</view></picker></view><view class="row-between field"><text class="field-label">自定义 Deadline</text><switch checked="{{deadlineEnabled}}" color="#2E7D5B" bindchange="toggleDeadline" /></view><view wx:if="{{deadlineEnabled}}" class="field"><picker mode="date" value="{{deadline}}" bindchange="updateDeadline"><view class="picker">截止 {{deadline}}</view></picker></view><view class="field"><text class="field-label">得分</text><input class="input" type="number" value="{{score}}" bindinput="updateScore" /></view><view class="field"><text class="field-label">负责人</text><picker range="{{members}}" range-key="name" value="{{memberIndex}}" bindchange="selectMember"><view class="picker">{{members[memberIndex].name}}</view></picker></view></view>
  <button class="button-primary save" bindtap="save">{{mode === 'adjust' ? '保存单次调整' : '创建临时任务'}}</button>
  <view wx:if="{{mode === 'adjust'}}" class="section card cancel-card"><text class="field-label danger">取消本次任务</text><textarea class="textarea" value="{{cancellationReason}}" placeholder="请输入取消原因" bindinput="updateCancellation" /><button class="button-danger cancel" bindtap="cancelTask">只取消本次</button></view>
</view>
