.add-button { width:140rpx;flex:none; }.rule { display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:20rpx; }.rule-icon { display:flex;align-items:center;justify-content:center;width:78rpx;height:78rpx;border-radius:24rpx;background:#e4f0e9; }.rule-icon image { width:44rpx;height:44rpx; }.rule-content { min-width:0; }.rule-title { font-size:33rpx;font-weight:780; }.score { color:#1f4d3b;font-weight:750; }.meta,.order { display:block;margin-top:11rpx;color:#68736d;font-size:24rpx;line-height:1.5; }.order { color:#476158; }
