<view class="page-shell" wx:if="{{ready}}">
  <view class="page-title">{{ruleID ? '编辑规则' : '新增规则'}}</view>
  <view class="card"><view class="field"><text class="field-label">任务名称</text><input class="input" value="{{title}}" placeholder="例如：洗碗" bindinput="updateTitle" /></view><view class="field"><text class="field-label">每周发生</text><picker range="{{weekdays}}" value="{{weekdayIndex}}" bindchange="updateWeekday"><view class="picker">{{weekdays[weekdayIndex]}}</view></picker></view><view class="field"><text class="field-label">轮换起始周</text><picker mode="date" value="{{startDate}}" bindchange="updateStart"><view class="picker">{{startDate}}</view></picker></view><view class="field"><text class="field-label">默认得分</text><input class="input" type="number" value="{{score}}" bindinput="updateScore" /></view><view class="row-between"><text class="field-label">启用规则</text><switch checked="{{enabled}}" color="#2E7D5B" bindchange="updateEnabled" /></view></view>
  <view class="section"><view class="section-title">参与成员</view><view class="chip-row"><button wx:for="{{members}}" wx:key="id" class="chip {{item.selected ? 'chip-selected' : ''}}" data-id="{{item.id}}" bindtap="toggleMember">{{item.name}}</button></view></view>
  <view class="section card"><view class="section-title">轮换顺序</view><view class="order-row" wx:for="{{order}}" wx:key="*this"><text class="order-number">{{index + 1}}</text><view class="order-member"><block wx:for="{{members}}" wx:key="id" wx:for-item="member"><text wx:if="{{member.id === item}}">{{member.name}}</text></block></view><button class="button-plain button-small" data-index="{{index}}" data-delta="-1" bindtap="moveMember" disabled="{{index === 0}}">上移</button><button class="button-plain button-small" data-index="{{index}}" data-delta="1" bindtap="moveMember" disabled="{{index === order.length - 1}}">下移</button></view></view>
  <button class="button-primary save" bindtap="save">保存规则</button>
</view>
